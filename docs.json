{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "Sixthgear Documentation",
  "description": "Private internal documentation for operating and maintaining the SixthGear website.",
  "colors": {
    "primary": "#92400E",
    "light": "#F16D34",
    "dark": "#F16D34"
  },
  "logo": {
    "light": "/images/brand/sixthgear-wordmark.png",
    "dark": "/images/brand/sixthgear-mark.png"
  },
  "favicon": "/images/brand/favicon.png",
  "appearance": {
    "default": "system"
  },
  "fonts": {
    "family": "Inter"
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view"]
  },
  "navigation": {
    "pages": [
      "index",
      "introduction",
      "initial-setup/overview",
      "sixthgear-cms/overview",
      "shopify/overview",
      "shopify/pos-platform-recommendation",
      "storefront-development/overview",
      "seo/overview",
      "deployment/overview",
      "accounts-and-access/overview",
      "operations/overview",
      "troubleshooting/overview",
      "turnover-and-maintenance/overview",
      "reference/overview",
      "sixthgear-guide"
    ]
  },
  "redirects": [
    { "source": "/start-here/overview", "destination": "/" },
    { "source": "/start-here/how-to-use-this-portal", "destination": "/" },
    { "source": "/start-here/documentation-status", "destination": "/" },
    { "source": "/architecture/system-overview", "destination": "/website/system-architecture" },
    { "source": "/architecture/integrations", "destination": "/systems-and-access/third-party-services" },
    { "source": "/architecture/environments", "destination": "/website/environment-variables" },
    { "source": "/access/account-register", "destination": "/systems-and-access/account-directory" },
    { "source": "/access/roles-and-ownership", "destination": "/systems-and-access/roles-permissions" },
    { "source": "/access/credential-security", "destination": "/systems-and-access/credential-security" },
    { "source": "/source-code/repository-overview", "destination": "/website/source-code-overview" },
    { "source": "/source-code/important-file-paths", "destination": "/website/source-code-overview" },
    { "source": "/deployment/production-overview", "destination": "/deployment/deployment-overview" },
    { "source": "/deployment/vercel-deployment", "destination": "/deployment/deploy-through-vercel" },
    { "source": "/deployment/rollback-overview", "destination": "/deployment/roll-back-deployment" },
    { "source": "/recovery/emergency-response", "destination": "/troubleshooting/emergency-recovery" },
    { "source": "/recovery/access-recovery", "destination": "/troubleshooting/emergency-recovery" }
  ]
}
